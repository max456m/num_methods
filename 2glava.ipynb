    ##№4
    "%matplotlib inline\n",
    "import math\n",
    "\n",
    "def f(x):\n",
    "    return 4*x**4 - 6.2 - math.cos(0.6*x)\n",
    "\n",
    "def df(x):\n",
    "    return 16*x**3 + 0.6*math.sin(0.6*x)\n",
    "\n",
    "x = 1.15\n",
    "eps = 1e-6\n",
    "\n",
    "while True:\n",
    "    x_new = x - f(x)/df(x)\n",
    "\n",
    "    if abs(x_new - x) < eps:\n",
    "        break\n",
    "\n",
    "    x = x_new\n",
    "\n",
    "print(x_new)"
   ]
  }
