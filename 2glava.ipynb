    ##№1
    "%matplotlib inline\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "x = np.linspace(-2, 2, 1000)\n",
    "\n",
    "y1 = 4*x**4 - 6.2\n",
    "y2 = np.cos(0.6*x)\n",
    "\n",
    "plt.plot(x, y1, label='4x^4 - 6.2')\n",
    "plt.plot(x, y2, label='cos(0.6x)')\n",
    "plt.grid(True)\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  },
