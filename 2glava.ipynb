    ##№3
    "%matplotlib inline\n",
    "import math\n",
    "\n",
    "def phi(x):\n",
    "    return ((6.2 + math.cos(0.6*x)) / 4) ** 0.25\n",
    "\n",
    "x = 1.15\n",
    "eps = 1e-6\n",
    "\n",
    "while True:\n",
    "    x_new = phi(x)\n",
    "\n",
    "    if abs(x_new - x) < eps:\n",
    "        break\n",
    "\n",
    "    x = x_new\n",
    "\n",
    "print(x_new)"
   ]
  },
