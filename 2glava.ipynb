    ##№2
    "%matplotlib inline\n",
    "import math\n",
    "\n",
    "def f(x):\n",
    "    return 4*x**4 - 6.2 - math.cos(0.6*x)\n",
    "\n",
    "a = 1.1\n",
    "b = 1.2\n",
    "eps = 1e-3\n",
    "\n",
    "while (b - a) / 2 > eps:\n",
    "    c = (a + b) / 2\n",
    "\n",
    "    if f(a) * f(c) <= 0:\n",
    "        b = c\n",
    "    else:\n",
    "        a = c\n",
    "\n",
    "root = (a + b) / 2\n",
    "print(root)"
   ]
